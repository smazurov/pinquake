{
  "components": {
    "schemas": {
      "AutoLockConfig": {
        "additionalProperties": false,
        "properties": {
          "epsilon": {
            "default": 0.01,
            "description": "Max change (g) to count as stable",
            "format": "double",
            "maximum": 1,
            "minimum": 0.001,
            "multipleOf": 0.001,
            "type": "number"
          },
          "timeout": {
            "default": 10,
            "description": "Seconds of stability before auto-lock",
            "format": "double",
            "maximum": 60,
            "minimum": 1,
            "type": "number"
          }
        },
        "required": [
          "timeout",
          "epsilon"
        ],
        "type": "object"
      },
      "BLEConfig": {
        "additionalProperties": false,
        "properties": {
          "device_address": {
            "type": "string"
          },
          "device_name": {
            "type": "string"
          },
          "sensor_name": {
            "type": "string"
          }
        },
        "required": [
          "device_address",
          "device_name",
          "sensor_name"
        ],
        "type": "object"
      },
      "BLEScanResultEvent": {
        "additionalProperties": false,
        "properties": {
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "rssi": {
            "format": "int64",
            "type": "integer"
          },
          "sensor_name": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "address",
          "name",
          "rssi",
          "timestamp"
        ],
        "type": "object"
      },
      "BLEStatusEvent": {
        "additionalProperties": false,
        "properties": {
          "device": {
            "type": "string"
          },
          "device_name": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "timestamp"
        ],
        "type": "object"
      },
      "BatteryEvent": {
        "additionalProperties": false,
        "properties": {
          "battery_percent": {
            "format": "int32",
            "minimum": 0,
            "type": "integer"
          },
          "battery_volts": {
            "format": "float",
            "type": "number"
          },
          "charging": {
            "type": "boolean"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "battery_percent",
          "battery_volts",
          "charging",
          "timestamp"
        ],
        "type": "object"
      },
      "ConfigChangedEvent": {
        "additionalProperties": false,
        "properties": {
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "timestamp"
        ],
        "type": "object"
      },
      "ConnectRequestBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ConnectRequestBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "address": {
            "description": "BLE MAC address",
            "examples": [
              "AA:BB:CC:DD:EE:FF"
            ],
            "type": "string"
          },
          "name": {
            "description": "BLE advertised name",
            "examples": [
              "WT901BLE50"
            ],
            "type": "string"
          }
        },
        "required": [
          "address",
          "name"
        ],
        "type": "object"
      },
      "CrosshairConfig": {
        "additionalProperties": false,
        "properties": {
          "bar_thickness": {
            "default": 12,
            "description": "Bar thickness (px)",
            "format": "int64",
            "maximum": 30,
            "minimum": 4,
            "type": "integer"
          },
          "force_red_g": {
            "default": 0.1,
            "description": "Red threshold (g)",
            "format": "double",
            "maximum": 1,
            "minimum": 0.01,
            "multipleOf": 0.01,
            "type": "number"
          },
          "force_yellow_g": {
            "default": 0.03,
            "description": "Yellow threshold (g)",
            "format": "double",
            "maximum": 0.5,
            "minimum": 0.001,
            "multipleOf": 0.001,
            "type": "number"
          },
          "segment_size": {
            "default": 10,
            "description": "Bar segment size (px)",
            "format": "int64",
            "maximum": 30,
            "minimum": 2,
            "type": "integer"
          },
          "smoothing": {
            "default": 0.7,
            "description": "Exponential smoothing factor",
            "format": "double",
            "maximum": 1,
            "minimum": 0,
            "multipleOf": 0.01,
            "type": "number"
          },
          "swap_xy": {
            "default": false,
            "description": "Swap X and Y axes",
            "type": "boolean"
          }
        },
        "required": [
          "force_yellow_g",
          "force_red_g",
          "smoothing",
          "segment_size",
          "bar_thickness",
          "swap_xy"
        ],
        "type": "object"
      },
      "ErrorDetail": {
        "additionalProperties": false,
        "properties": {
          "location": {
            "description": "Where the error occurred, e.g. 'body.items[3].tags' or 'path.thing-id'",
            "type": "string"
          },
          "message": {
            "description": "Error message text",
            "type": "string"
          },
          "value": {
            "description": "The value at the given location"
          }
        },
        "type": "object"
      },
      "ErrorModel": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ErrorModel.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "detail": {
            "description": "A human-readable explanation specific to this occurrence of the problem.",
            "examples": [
              "Property foo is required but is missing."
            ],
            "type": "string"
          },
          "errors": {
            "description": "Optional list of individual error details",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "instance": {
            "description": "A URI reference that identifies the specific occurrence of the problem.",
            "examples": [
              "https://example.com/error-log/abc123"
            ],
            "format": "uri",
            "type": "string"
          },
          "status": {
            "description": "HTTP status code",
            "examples": [
              400
            ],
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "A short, human-readable summary of the problem type. This value should not change between occurrences of the error.",
            "examples": [
              "Bad Request"
            ],
            "type": "string"
          },
          "type": {
            "default": "about:blank",
            "description": "A URI reference to human-readable documentation for the error.",
            "examples": [
              "https://example.com/errors/example"
            ],
            "format": "uri",
            "type": "string"
          }
        },
        "type": "object"
      },
      "FrameStateBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/FrameStateBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "locked": {
            "type": "boolean"
          }
        },
        "required": [
          "locked"
        ],
        "type": "object"
      },
      "HeartbeatEvent": {
        "additionalProperties": false,
        "properties": {
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "timestamp"
        ],
        "type": "object"
      },
      "LogEntry": {
        "additionalProperties": false,
        "properties": {
          "level": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "level",
          "timestamp"
        ],
        "type": "object"
      },
      "OKBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/OKBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "type": "object"
      },
      "OrientationEvent": {
        "additionalProperties": false,
        "properties": {
          "gx": {
            "format": "float",
            "type": "number"
          },
          "gy": {
            "format": "float",
            "type": "number"
          },
          "gz": {
            "format": "float",
            "type": "number"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "required": [
          "gx",
          "gy",
          "gz",
          "timestamp"
        ],
        "type": "object"
      },
      "PinQuakeConfig": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/PinQuakeConfig.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "auto_lock": {
            "$ref": "#/components/schemas/AutoLockConfig"
          },
          "ble": {
            "$ref": "#/components/schemas/BLEConfig"
          },
          "crosshair": {
            "$ref": "#/components/schemas/CrosshairConfig"
          },
          "viz": {
            "$ref": "#/components/schemas/VizConfig"
          },
          "waveform": {
            "$ref": "#/components/schemas/WaveformConfig"
          }
        },
        "required": [
          "ble",
          "waveform",
          "crosshair",
          "viz",
          "auto_lock"
        ],
        "type": "object"
      },
      "VizConfig": {
        "additionalProperties": false,
        "properties": {
          "height": {
            "examples": [
              1080
            ],
            "format": "int64",
            "type": "integer"
          },
          "width": {
            "examples": [
              1920
            ],
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "width",
          "height"
        ],
        "type": "object"
      },
      "WaveformConfig": {
        "additionalProperties": false,
        "properties": {
          "amp_scale": {
            "default": 1,
            "description": "Amplitude multiplier",
            "format": "double",
            "maximum": 5,
            "minimum": 0.1,
            "multipleOf": 0.1,
            "type": "number"
          },
          "buffer_size": {
            "default": 256,
            "description": "Ring buffer sample count",
            "format": "int64",
            "maximum": 512,
            "minimum": 32,
            "type": "integer"
          },
          "force_red_g": {
            "default": 0.1,
            "description": "Red threshold (g)",
            "format": "double",
            "maximum": 1,
            "minimum": 0.01,
            "multipleOf": 0.01,
            "type": "number"
          },
          "force_yellow_g": {
            "default": 0.03,
            "description": "Yellow threshold (g)",
            "format": "double",
            "maximum": 0.5,
            "minimum": 0.001,
            "multipleOf": 0.001,
            "type": "number"
          },
          "log_knee": {
            "default": 0.02,
            "description": "Log compression knee",
            "format": "double",
            "maximum": 0.1,
            "minimum": 0.001,
            "multipleOf": 0.001,
            "type": "number"
          },
          "swap_xy": {
            "default": false,
            "description": "Swap X and Y axes",
            "type": "boolean"
          }
        },
        "required": [
          "buffer_size",
          "log_knee",
          "force_yellow_g",
          "force_red_g",
          "amp_scale",
          "swap_xy"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "BLE orientation data visualization",
    "title": "PinQuake API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/ble/connect": {
      "post": {
        "operationId": "post-api-ble-connect",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectRequestBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OKBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Post API ble connect",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/disconnect": {
      "post": {
        "operationId": "post-api-ble-disconnect",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OKBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Post API ble disconnect",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/frame": {
      "get": {
        "operationId": "get-api-ble-frame",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FrameStateBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get API ble frame",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/frame/force-lock": {
      "post": {
        "operationId": "post-api-ble-frame-force-lock",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OKBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Post API ble frame force lock",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/frame/lock": {
      "post": {
        "operationId": "post-api-ble-frame-lock",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OKBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Post API ble frame lock",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/frame/unlock": {
      "post": {
        "operationId": "post-api-ble-frame-unlock",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OKBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Post API ble frame unlock",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/ble/scan": {
      "get": {
        "description": "Opening this connection starts scanning; closing it stops scanning",
        "operationId": "ble-scan",
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "description": "Each oneOf object in the array represents one possible Server Sent Events (SSE) message, serialized as UTF-8 text according to the SSE specification.",
                  "items": {
                    "oneOf": [
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/BLEScanResultEvent"
                          },
                          "event": {
                            "const": "device",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event device",
                        "type": "object"
                      }
                    ]
                  },
                  "title": "Server Sent Events",
                  "type": "array"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "BLE scan SSE stream",
        "tags": [
          "ble"
        ]
      }
    },
    "/api/config": {
      "get": {
        "operationId": "get-api-config",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinQuakeConfig"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get API config",
        "tags": [
          "config"
        ]
      },
      "put": {
        "operationId": "put-api-config",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PinQuakeConfig"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinQuakeConfig"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Put API config",
        "tags": [
          "config"
        ]
      }
    },
    "/api/events": {
      "get": {
        "description": "Real-time orientation data and BLE status events",
        "operationId": "events-stream",
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "description": "Each oneOf object in the array represents one possible Server Sent Events (SSE) message, serialized as UTF-8 text according to the SSE specification.",
                  "items": {
                    "oneOf": [
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/BatteryEvent"
                          },
                          "event": {
                            "const": "battery",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event battery",
                        "type": "object"
                      },
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/BLEStatusEvent"
                          },
                          "event": {
                            "const": "ble-status",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event ble-status",
                        "type": "object"
                      },
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/ConfigChangedEvent"
                          },
                          "event": {
                            "const": "config-changed",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event config-changed",
                        "type": "object"
                      },
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/HeartbeatEvent"
                          },
                          "event": {
                            "const": "heartbeat",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event heartbeat",
                        "type": "object"
                      },
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/LogEntry"
                          },
                          "event": {
                            "const": "log",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
                            "type": "integer"
                          }
                        },
                        "required": [
                          "data",
                          "event"
                        ],
                        "title": "Event log",
                        "type": "object"
                      },
                      {
                        "properties": {
                          "data": {
                            "$ref": "#/components/schemas/OrientationEvent"
                          },
                          "event": {
                            "const": "orientation",
                            "description": "The event name.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The event ID.",
                            "type": "integer"
                          },
                          "retry": {
                            "description": "The retry time in milliseconds.",
